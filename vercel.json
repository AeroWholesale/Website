{
    "buildCommand":  "vite build",
    "outputDirectory":  "dist",
    "rewrites":  [
                     {
                         "source":  "/((?!api|assets|_next).*)",
                         "destination":  "/index.html"
                     }
                 ],
    "crons":  [
                  {
                      "path":  "/api/cron/sync-inventory",
                      "schedule":  "0 * * * *"
                  }
              ]
}
